{
  "name": "afro-genie-server",
  "version": "1.0.0",
  "private": true,
  "type": "commonjs",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "prisma generate && tsc -p tsconfig.json",
    "start": "prisma migrate deploy && prisma generate && node dist/index.js",
    "lint": "npm run prisma:generate && tsc --noEmit",
    "type-check": "npm run prisma:generate && tsc --noEmit",
    "test": "node --test",
    "test:schema": "tsx scripts/test-schema.ts",
    "test:translations": "tsx scripts/translation-acceptance-test.ts",
    "test:lyrics-enrichment": "tsx scripts/lyrics-enrichment-acceptance-test.ts",
    "test:community": "tsx scripts/community-acceptance-test.ts",
    "search:index": "tsx scripts/indexExistingSongs.ts",
    "spotify:backfill": "tsx scripts/backfillSpotifyIds.ts",
    "spotify:backfill:dry": "tsx scripts/backfillSpotifyIds.ts --dry-run",
    "search:bulk": "tsx -e \"import('./src/services/searchService').then((m)=>m.bulkIndex())\"",
    "docs:api:generate": "tsx scripts/generate-openapi-json.ts",
    "docs:api:build": "npm run docs:api:generate",
    "prisma:generate": "prisma generate",
    "prisma:seed": "prisma db seed",
    "seed:batch": "tsx scripts/batch-seed.ts",
    "seed:resume": "tsx scripts/batch-seed.ts --resume",
    "seed:monitor": "tsx scripts/seed-monitor.ts",
    "seed:status": "tsx scripts/seed-monitor.ts --once",
    "link:data": "tsx scripts/link-song-data.ts",
    "link:dry": "tsx scripts/link-song-data.ts --dry-run",
    "link:genres": "tsx scripts/link-song-data.ts --genres-only",
    "link:languages": "tsx scripts/link-song-data.ts --languages-only",
    "db:status": "tsx scripts/db-status.ts",
    "seed:community": "tsx scripts/seed-community.ts",
    "seed:robust": "tsx scripts/robust-seed.ts",
    "seed:robust:resume": "tsx scripts/robust-seed.ts --resume",
    "seed:robust:status": "tsx scripts/robust-seed.ts --status",
    "audit:seed": "tsx scripts/audit-seed-data.ts",
    "audit:artists": "tsx scripts/audit-artists.ts",
    "audit:artists:json": "tsx scripts/audit-artists.ts --json",
    "backfill:artists": "tsx scripts/backfill-artists.ts",
    "backfill:artists:dry": "tsx scripts/backfill-artists.ts --dry-run",
    "backfill:artists:priority": "tsx scripts/backfill-artists.ts --priority",
    "backfill:artists:priority:dry": "tsx scripts/backfill-artists.ts --priority --dry-run",
    "seed:full": "tsx scripts/scheduled-seed.ts",
    "seed:artist-portal": "tsx scripts/seed-artist-portal.ts"
  },
  "dependencies": {
    "@google/genai": "^2.12.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcrypt": "^5.1.1",
    "bullmq": "^5.22.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "express-rate-limit": "^7.4.1",
    "express-validator": "^7.2.0",
    "franc-min": "^6.2.0",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^6.10.0",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "pg": "^8.13.1",
    "pino": "^9.5.0",
    "pino-http": "^10.3.0",
    "typesense": "^2.0.0-rc.2",
    "zod": "^3.23.8"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.1",
    "@types/nodemailer": "^6.4.16",
    "@types/passport": "^1.0.17",
    "@types/passport-google-oauth20": "^2.0.16",
    "@types/pg": "^8.11.10",
    "prisma": "^7.8.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
